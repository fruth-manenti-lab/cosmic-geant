<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<gdml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="./schema/gdml.xsd">

    <!-- Baseline copy of main3.gdml for incremental edits.
         Current changes from main3:
         1. one 1 m x 1 m slab instead of four quadrants
         2. SiPMs only on the positive sides (+z and +x)
         3. 1.2 mm square air grooves with floating Kuraray fibers
         4. aluminum foil wrapper with perforated side faces for fiber stubs -->

    <define>
        <position name="roofpos" x="0" y="60" z="0" unit="cm"/>
        <rotation name="sipm_to_z" x="90" unit="deg"/>
        <rotation name="sipm_to_x" z="90" unit="deg"/>
        <rotation name="fiber_to_x" y="90" unit="deg"/>

        <variable name="sipmXIndex" value="0"/>
        <variable name="sipmZIndex" value="0"/>
        <variable name="grooveXIndex" value="0"/>
        <variable name="grooveZIndex" value="0"/>

        <!-- Geometry stack-up parameters in mm. -->
        <variable name="slab_half_xy" value="500"/>
        <variable name="slab_half_y" value="10"/>
        <variable name="lane_pitch" value="62.5"/>
        <variable name="lane_start" value="-468.75"/>
        <variable name="groove_half_y" value="0.6"/>
        <variable name="stub_half_len" value="5"/>
        <variable name="grease_half_len" value="0.05"/>
        <variable name="sipm_half_len" value="0.25"/>
        <variable name="placement_clearance" value="0.02"/>
        <variable name="foil_half_thickness" value="0.025"/>
        <variable name="stub_outer_size" value="1.04"/>
        <variable name="foil_hole_clearance" value="0.02"/>
        <variable name="foil_hole_size" value="stub_outer_size+foil_hole_clearance"/>
        <variable name="groove_bottom_y" value="-slab_half_y+groove_half_y"/>
        <variable name="groove_top_y" value="slab_half_y-groove_half_y"/>
        <variable name="stub_neg_pos" value="-slab_half_xy-stub_half_len"/>
        <variable name="stub_pos_pos" value="slab_half_xy+stub_half_len"/>
        <variable name="grease_pos_pos" value="slab_half_xy+2*stub_half_len+grease_half_len"/>
        <variable name="sipm_pos_pos" value="slab_half_xy+2*stub_half_len+2*grease_half_len+sipm_half_len"/>
        <variable name="foil_x_pos" value="slab_half_xy+foil_half_thickness"/>
        <variable name="foil_z_pos" value="slab_half_xy+foil_half_thickness"/>
        <variable name="foil_top_pos" value="slab_half_y+foil_half_thickness"/>
        <variable name="foil_bottom_pos" value="-slab_half_y-foil_half_thickness"/>

