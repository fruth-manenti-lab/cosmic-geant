        <matrix name="SIPM_EFFICIENCY" coldim="2" values="1.5*eV 1.0 6.5*eV 1.0"/>
        <matrix name="SIPM_REFLECTIVITY" coldim="1" values="0.0"/>
    </define>

    <materials>
        <element Z="12" name="C" formula="C">
            <atom unit="g/mole" value="12"/>
        </element>
        <element Z="1" name="H" formula="H">
            <atom unit="g/mole" value="1"/>
        </element>
        <element Z="14" name="Si" formula="Si">
            <atom unit="g/mole" value="28.085"/>
        </element>
        <element Z="13" name="Al" formula="Al">
            <atom unit="g/mole" value="26.9815385"/>
        </element>
        <element Z="35" name="Br" formula="Br">
            <atom unit="g/mole" value="79.904"/>
        </element>
        <element Z="58" name="Ce" formula="Ce">
            <atom unit="g/mole" value="140.116"/>
        </element>
        <isotope N="14" Z="7" name="N14">
            <atom unit="g/mole" value="14.0031"/>
        </isotope>
        <isotope N="15" Z="7" name="N15">
            <atom unit="g/mole" value="15.0001"/>
        </isotope>
        <element name="Nitrogen">
            <fraction n="0.99632" ref="N14"/>
            <fraction n="0.00368" ref="N15"/>
        </element>
        <isotope N="16" Z="8" name="O16">
            <atom unit="g/mole" value="15.9949"/>
        </isotope>
        <isotope N="17" Z="8" name="O17">
            <atom unit="g/mole" value="16.9991"/>
        </isotope>
        <isotope N="18" Z="8" name="O18">
            <atom unit="g/mole" value="17.9992"/>
        </isotope>
        <element name="Oxygen">
            <fraction n="0.99757" ref="O16"/>
            <fraction n="0.00038" ref="O17"/>
            <fraction n="0.00205" ref="O18"/>
        </element>

        <material name="PVT" state="solid">
            <D value="1.05" unit="g/cm3"/>
            <property name="ABSLENGTH" ref="PVTALEN"/>
            <property name="RINDEX" ref="PVTRINDEX"/>
            <property name="SCINTILLATIONCOMPONENT1" ref="PVTSC"/>
            <property name="SCINTILLATIONCOMPONENT2" ref="PVTSC"/>
            <property name="RESOLUTIONSCALE" ref="PVTRESOLUTIONSCALE"/>
            <property name="SCINTILLATIONYIELD" ref="PVTSCINTILLATIONYIELD"/>
            <property name="MIEHG" ref="PVTMIEHG"/>
            <property name="MIEHG_FORWARD" ref="PVTMIEHG_FORWARD"/>
            <property name="MIEHG_BACKWARD" ref="PVTMIEHG_BACKWARD"/>
            <property name="MIEHG_FORWARD_RATIO" ref="PVTMIEHG_FORWARD_RATIO"/>
            <property name="SCINTILLATIONTIMECONSTANT1" ref="PVTSCINTILLATIONTIMECONSTANT1"/>
            <property name="SCINTILLATIONTIMECONSTANT2" ref="PVTSCINTILLATIONTIMECONSTANT2"/>
            <property name="SCINTILLATIONYIELD1" ref="SCINTILLATIONYIELD1"/>
            <property name="SCINTILLATIONYIELD2" ref="SCINTILLATIONYIELD2"/>
            <composite n="9" ref="C"/>
            <composite n="10" ref="H"/>
        </material>

        <material name="CeBr3" state="solid">
            <D value="5.1" unit="g/cm3"/>
            <composite n="1" ref="Ce"/>
            <composite n="3" ref="Br"/>
        </material>

        <material name="Air" state="gas">
            <property name="RINDEX" ref="AIRRINDEX"/>
            <T unit="K" value="293.15"/>
            <MEE unit="eV" value="85.7030667332998"/>
            <D unit="g/cm3" value="0.00129"/>
            <fraction n="0.7" ref="Nitrogen"/>
            <fraction n="0.3" ref="Oxygen"/>
        </material>

        <material name="SiMat" state="solid">
            <D value="2.33" unit="g/cm3"/>
            <property name="RINDEX" ref="SIRINDEX"/>
            <composite n="1" ref="Si"/>
        </material>

        <material name="OpticalGrease" state="solid">
            <D value="1.0" unit="g/cm3"/>
            <property name="RINDEX" ref="GREASERINDEX"/>
            <property name="ABSLENGTH" ref="GREASEABSLENGTH"/>
            <composite n="2" ref="C"/>
            <composite n="6" ref="H"/>
        </material>

        <material name="Aluminum" state="solid">
            <D value="2.7" unit="g/cm3"/>
            <composite n="1" ref="Al"/>
        </material>
    </materials>

    <solids>
        <box lunit="m" name="world_solid" x="2" y="2" z="2"/>
        <box lunit="mm" name="scint_solid" x="1000" y="2*slab_half_y" z="1000"/>
        <box lunit="mm" name="groove_z_solid" x="1.2" y="1.2" z="1000"/>
        <box lunit="mm" name="groove_x_solid" x="1000" y="1.2" z="1.2"/>
        <box lunit="mm" name="grease_solid" x="1" y="0.1" z="1"/>
        <box lunit="mm" name="foil_y_face_solid" x="1000" y="0.05" z="1000"/>
        <box lunit="mm" name="foil_x_face_base" x="0.05" y="2*slab_half_y" z="1000"/>
        <box lunit="mm" name="foil_z_face_base" x="1000" y="2*slab_half_y" z="0.05"/>
        <!-- Match the perforations to the 1.04 mm coated stub envelope with only a
             small clearance so the foil does not leave a large optical escape gap. -->
        <box lunit="mm" name="foil_x_hole" x="0.051" y="foil_hole_size" z="foil_hole_size"/>
        <box lunit="mm" name="foil_z_hole" x="foil_hole_size" y="foil_hole_size" z="0.051"/>

        <subtraction name="foil_x_face_step_0">
            <first ref="foil_x_face_base"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 0*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_1">
            <first ref="foil_x_face_step_0"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 1*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_2">
            <first ref="foil_x_face_step_1"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 2*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_3">
            <first ref="foil_x_face_step_2"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 3*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_4">
            <first ref="foil_x_face_step_3"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 4*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_5">
            <first ref="foil_x_face_step_4"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 5*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_6">
            <first ref="foil_x_face_step_5"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 6*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_7">
            <first ref="foil_x_face_step_6"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 7*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_8">
            <first ref="foil_x_face_step_7"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 8*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_9">
            <first ref="foil_x_face_step_8"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 9*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_10">
            <first ref="foil_x_face_step_9"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 10*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_11">
            <first ref="foil_x_face_step_10"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 11*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_12">
            <first ref="foil_x_face_step_11"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 12*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_13">
            <first ref="foil_x_face_step_12"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 13*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_14">
            <first ref="foil_x_face_step_13"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 14*lane_pitch" unit="mm"/>
        </subtraction>
        <subtraction name="foil_x_face_step_15">
            <first ref="foil_x_face_step_14"/>
            <second ref="foil_x_hole"/>
            <position x="0" y="groove_top_y" z="lane_start + 15*lane_pitch" unit="mm"/>
        </subtraction>

        <subtraction name="foil_z_face_step_0">
            <first ref="foil_z_face_base"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 0*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_1">
            <first ref="foil_z_face_step_0"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 1*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_2">
            <first ref="foil_z_face_step_1"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 2*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_3">
            <first ref="foil_z_face_step_2"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 3*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_4">
            <first ref="foil_z_face_step_3"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 4*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_5">
            <first ref="foil_z_face_step_4"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 5*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_6">
            <first ref="foil_z_face_step_5"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 6*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_7">
            <first ref="foil_z_face_step_6"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 7*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_8">
            <first ref="foil_z_face_step_7"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 8*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_9">
            <first ref="foil_z_face_step_8"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 9*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_10">
            <first ref="foil_z_face_step_9"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 10*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_11">
            <first ref="foil_z_face_step_10"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 11*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_12">
            <first ref="foil_z_face_step_11"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 12*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_13">
            <first ref="foil_z_face_step_12"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 13*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_14">
            <first ref="foil_z_face_step_13"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 14*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>
        <subtraction name="foil_z_face_step_15">
            <first ref="foil_z_face_step_14"/>
            <second ref="foil_z_hole"/>
            <position x="lane_start + 15*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
        </subtraction>

        <!-- <opticalsurface name="aluminum_foil_surface" model="unified" finish="polished" type="dielectric_metal" value="0.0"> -->
        <opticalsurface name="aluminum_foil_surface" model="LUT" finish="groundteflonair" type="dielectric_LUT" value="1.0">
            <!-- <property name="REFLECTIVITY" ref="ALFOIL_REFLECTIVITY"/>
            <property name="EFFICIENCY" ref="ALFOIL_EFFICIENCY"/> -->
        </opticalsurface>
    </solids>

    <structure>
        <volume name="groove_z">
            <materialref ref="OpticalGrease"/>
            <solidref ref="groove_z_solid"/>
            <auxiliary auxtype="Color" auxvalue="0.6 0.9 1.0"/>
            <auxiliary auxtype="Transparency" auxvalue="0.1"/>
            <physvol>
                <file name="./geometry/fiber_kuraray_embedded.gdml"/>
            </physvol>
        </volume>

        <volume name="groove_x">
            <materialref ref="OpticalGrease"/>
            <solidref ref="groove_x_solid"/>
            <auxiliary auxtype="Color" auxvalue="0.6 0.9 1.0"/>
            <auxiliary auxtype="Transparency" auxvalue="0.1"/>
            <physvol>
                <file name="./geometry/fiber_kuraray_embedded.gdml"/>
                <rotationref ref="fiber_to_x"/>
            </physvol>
        </volume>

        <volume name="grease">
            <materialref ref="OpticalGrease"/>
            <solidref ref="grease_solid"/>
            <auxiliary auxtype="Color" auxvalue="1.0 0.8 0.2"/>
            <auxiliary auxtype="Transparency" auxvalue="0.15"/>
        </volume>

        <volume name="foil_y_face">
            <materialref ref="Aluminum"/>
            <solidref ref="foil_y_face_solid"/>
            <auxiliary auxtype="Color" auxvalue="0.8 0.8 0.85"/>
            <auxiliary auxtype="Transparency" auxvalue="0.55"/>
        </volume>

        <volume name="foil_x_face">
            <materialref ref="Aluminum"/>
            <solidref ref="foil_x_face_step_15"/>
            <auxiliary auxtype="Color" auxvalue="0.8 0.8 0.85"/>
            <auxiliary auxtype="Transparency" auxvalue="0.55"/>
        </volume>

        <volume name="foil_z_face">
            <materialref ref="Aluminum"/>
            <solidref ref="foil_z_face_step_15"/>
            <auxiliary auxtype="Color" auxvalue="0.8 0.8 0.85"/>
            <auxiliary auxtype="Transparency" auxvalue="0.55"/>
        </volume>

        <volume name="scintillator_slab">
            <materialref ref="PVT"/>
            <solidref ref="scint_solid"/>
            <auxiliary auxtype="Color" auxvalue="1 1 1"/>
            <auxiliary auxtype="Transparency" auxvalue="0.65"/>

            <!-- Bottom-side z-running air grooves. -->
            <loop for="grooveXIndex" to="15" step="1">
                <physvol>
                    <volumeref ref="groove_z"/>
                    <position x="lane_start + grooveXIndex*lane_pitch" y="groove_bottom_y" z="0" unit="mm"/>
                </physvol>
            </loop>

            <!-- Top-side x-running air grooves. -->
            <loop for="grooveZIndex" to="15" step="1">
                <physvol>
                    <volumeref ref="groove_x"/>
                    <position x="0" y="groove_top_y" z="lane_start + grooveZIndex*lane_pitch" unit="mm"/>
                </physvol>
            </loop>
        </volume>

        <volume name="world_volume">
            <materialref ref="Air"/>
            <solidref ref="world_solid"/>

            <physvol name="slab_phys">
                <volumeref ref="scintillator_slab"/>
            </physvol>

            <physvol name="foil_top_phys">
                <volumeref ref="foil_y_face"/>
                <position x="0" y="foil_top_pos" z="0" unit="mm"/>
            </physvol>

            <physvol name="foil_bottom_phys">
                <volumeref ref="foil_y_face"/>
                <position x="0" y="foil_bottom_pos" z="0" unit="mm"/>
            </physvol>

            <physvol name="foil_posx_phys">
                <volumeref ref="foil_x_face"/>
                <position x="foil_x_pos" y="0" z="0" unit="mm"/>
            </physvol>

            <physvol name="foil_negx_phys">
                <volumeref ref="foil_x_face"/>
                <position x="-foil_x_pos" y="0" z="0" unit="mm"/>
            </physvol>

            <physvol name="foil_posz_phys">
                <volumeref ref="foil_z_face"/>
                <position x="0" y="0" z="foil_z_pos" unit="mm"/>
            </physvol>

            <physvol name="foil_negz_phys">
                <volumeref ref="foil_z_face"/>
                <position x="0" y="0" z="-foil_z_pos" unit="mm"/>
            </physvol>

            <physvol>
                <positionref ref="roofpos"/>
                <file name="./geometry/roof.gdml"/>
            </physvol>

            <!-- +z family: negative stub only, positive stub + grease + SiPM. -->
            <loop for="sipmXIndex" to="15" step="1">
                <physvol copynumber="25+sipmXIndex">
                    <file name="./geometry/fiber_kuraray_stub_capped.gdml"/>
                    <position x="lane_start + sipmXIndex*lane_pitch" y="groove_bottom_y" z="stub_neg_pos" unit="mm"/>
                </physvol>
                <physvol copynumber="50+sipmXIndex">
                    <file name="./geometry/fiber_kuraray_stub.gdml"/>
                    <position x="lane_start + sipmXIndex*lane_pitch" y="groove_bottom_y" z="stub_pos_pos" unit="mm"/>
                </physvol>
                <physvol copynumber="75+sipmXIndex">
                    <volumeref ref="grease"/>
                    <position x="lane_start + sipmXIndex*lane_pitch" y="groove_bottom_y" z="grease_pos_pos" unit="mm"/>
                    <rotationref ref="sipm_to_z"/>
                </physvol>
                <physvol copynumber="100+sipmXIndex">
                    <file name="./geometry/sipm1.gdml"/>
                    <position x="lane_start + sipmXIndex*lane_pitch" y="groove_bottom_y" z="sipm_pos_pos" unit="mm"/>
                    <rotationref ref="sipm_to_z"/>
                </physvol>
            </loop>

            <!-- +x family: negative stub only, positive stub + grease + SiPM. -->
            <loop for="sipmZIndex" to="15" step="1">
                <physvol copynumber="225+sipmZIndex">
                    <file name="./geometry/fiber_kuraray_stub_capped.gdml"/>
                    <position x="stub_neg_pos" y="groove_top_y" z="lane_start + sipmZIndex*lane_pitch" unit="mm"/>
                    <rotationref ref="fiber_to_x"/>
                </physvol>
                <physvol copynumber="250+sipmZIndex">
                    <file name="./geometry/fiber_kuraray_stub.gdml"/>
                    <position x="stub_pos_pos" y="groove_top_y" z="lane_start + sipmZIndex*lane_pitch" unit="mm"/>
                    <rotationref ref="fiber_to_x"/>
                </physvol>
                <physvol copynumber="275+sipmZIndex">
                    <volumeref ref="grease"/>
                    <position x="grease_pos_pos" y="groove_top_y" z="lane_start + sipmZIndex*lane_pitch" unit="mm"/>
                    <rotationref ref="sipm_to_x"/>
                </physvol>
                <physvol copynumber="300+sipmZIndex">
                    <file name="./geometry/sipm1.gdml"/>
                    <position x="sipm_pos_pos" y="groove_top_y" z="lane_start + sipmZIndex*lane_pitch" unit="mm"/>
                    <rotationref ref="sipm_to_x"/>
                </physvol>
            </loop>
        </volume>

        <bordersurface name="slab_to_foil_top" surfaceproperty="aluminum_foil_surface">
            <physvolref ref="slab_phys"/>
            <physvolref ref="foil_top_phys"/>
        </bordersurface>

        <bordersurface name="slab_to_foil_bottom" surfaceproperty="aluminum_foil_surface">
            <physvolref ref="slab_phys"/>
            <physvolref ref="foil_bottom_phys"/>
        </bordersurface>

        <bordersurface name="slab_to_foil_posx" surfaceproperty="aluminum_foil_surface">
            <physvolref ref="slab_phys"/>
            <physvolref ref="foil_posx_phys"/>
        </bordersurface>

        <bordersurface name="slab_to_foil_negx" surfaceproperty="aluminum_foil_surface">
            <physvolref ref="slab_phys"/>
            <physvolref ref="foil_negx_phys"/>
        </bordersurface>

        <bordersurface name="slab_to_foil_posz" surfaceproperty="aluminum_foil_surface">
            <physvolref ref="slab_phys"/>
            <physvolref ref="foil_posz_phys"/>
        </bordersurface>

        <bordersurface name="slab_to_foil_negz" surfaceproperty="aluminum_foil_surface">
            <physvolref ref="slab_phys"/>
            <physvolref ref="foil_negz_phys"/>
        </bordersurface>

        <skinsurface name="foil_y_skin" surfaceproperty="aluminum_foil_surface">
            <volumeref ref="foil_y_face"/>
        </skinsurface>

        <skinsurface name="foil_x_skin" surfaceproperty="aluminum_foil_surface">
            <volumeref ref="foil_x_face"/>
        </skinsurface>

        <skinsurface name="foil_z_skin" surfaceproperty="aluminum_foil_surface">
            <volumeref ref="foil_z_face"/>
        </skinsurface>
    </structure>

    <setup name="Default" version="1.0">
        <world ref="world_volume"/>
    </setup>
</gdml>
