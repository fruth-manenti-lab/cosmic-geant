<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<gdml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="./schema/gdml.xsd">

    <define>
        <matrix coldim="2" name="AIRRINDEX"
                values="2.25*eV 1.0 2.48*eV 1.0 2.76*eV 1.0 3.10*eV 1.0 3.54*eV 1.0"/>
    </define>

    <materials>
        <element Z="7" name="N">
            <atom unit="g/mole" value="14.007"/>
        </element>
        <element Z="8" name="O">
            <atom unit="g/mole" value="15.999"/>
        </element>

        <material name="Air" state="gas">
            <property name="RINDEX" ref="AIRRINDEX"/>
            <D value="0.00129" unit="g/cm3"/>
            <fraction n="0.7" ref="N"/>
            <fraction n="0.3" ref="O"/>
        </material>
    </materials>

    <solids>
        <box name="world_solid" x="50" y="50" z="60" lunit="cm"/>
    </solids>

    <structure>
        <volume name="world_volume">
            <materialref ref="Air"/>
            <solidref ref="world_solid"/>
            <physvol>
                <file name="./geometry/fiber_alternative.gdml"/>
                <position x="0" y="0" z="0" unit="mm"/>
            </physvol>
        </volume>
    </structure>

    <setup name="Default" version="1.0">
        <world ref="world_volume"/>
    </setup>
</gdml>
